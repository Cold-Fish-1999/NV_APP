# ============ Server (apps/server) ============
# 在 apps/server 目录创建 .env.local，或项目根目录 .env

# Supabase 项目 URL（Dashboard → Project Settings → API）
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Service Role Key（仅供服务端，切勿暴露到前端）
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============ Mobile (apps/mobile) ============
# 使用 EXPO_PUBLIC_ 前缀，会在构建时注入
# 可通过 app.json extra 或 .env 配置

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
