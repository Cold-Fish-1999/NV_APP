# ============ Server (apps/server) ============
# 在 apps/server 目录创建 .env.local，或项目根目录 .env

# Supabase 项目 URL（Dashboard → Project Settings → API）
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Service Role Key（仅供服务端，切勿暴露到前端）
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI：资料上传 AI 分析（POST /api/profile-document-analyze），默认 gpt-4o
# PROFILE_DOC_MODEL=gpt-4o

# Chat：生产环境在服务端控制台打印完整 Anthropic system + messages + tools（图片 base64 会脱敏）
# CHAT_LOG_FULL_PROMPT=1

# ============ Mobile (apps/mobile) ============
# 使用 EXPO_PUBLIC_ 前缀，会在构建时注入
# 在 apps/mobile/.env 配置（勿提交仓库）
#
# 真机连本机 Next：填电脑局域网 IP（Mac: ipconfig getifaddr en0），DHCP 会变需重配
# EXPO_PUBLIC_API_URL=http://10.0.0.x:3000

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
