{
  "expo": {
    "name": "NVAPP",
    "slug": "nvapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nvapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nvapp.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "用于语音输入并转换为文本发送到聊天。",
        "NSLocationWhenInUseUsageDescription": "用于获取您所在地的天气信息，显示在日历时间线上。",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nvapp.mobile",
      "permissions": ["RECORD_AUDIO", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"]
  }
}
