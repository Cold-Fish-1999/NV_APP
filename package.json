{
  "name": "nvapp",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm -r run build",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev:mobile\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "pnpm@9.14.2",
  "pnpm": {
    "patchedDependencies": {
      "react-native@0.81.0": "patches/react-native@0.81.0.patch"
    }
  }
}
